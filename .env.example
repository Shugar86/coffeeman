# Скопируйте в .env и подставьте значения.

# Секрет Payload (случайная длинная строка)
PAYLOAD_SECRET=change-me-to-a-long-random-string

# PostgreSQL (порт 5433 на хосте — см. docker-compose.yml в этом репозитории)
DATABASE_URL=postgres://coffeeman:coffeeman@127.0.0.1:5433/coffeeman

# Публичный URL приложения (для админки и ссылок)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Почта (менеджер при новом заказе)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MANAGER_EMAIL=

# Webhook оплаты (заглушка /api/payment/webhook)
# PAYMENT_WEBHOOK_SECRET=
